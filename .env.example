# Clerk — https://dashboard.clerk.com → API Keys
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxx

PUBLIC_CLERK_SIGN_IN_URL=/sign-in
PUBLIC_CLERK_SIGN_UP_URL=/sign-up
PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?appName=Cluster0

# File uploads — local: ./uploads | Render: /var/data/uploads
UPLOAD_DIR=./uploads

# Upload body size for adapter-node (videos up to 25MB)
BODY_SIZE_LIMIT=26M

# Site URL
# Local:              http://localhost:5173
# Testing (Render):   https://thegamesifinished.onrender.com
# Final domain later: https://www.gamesifinished.com
ORIGIN=https://thegamesifinished.onrender.com

# RAWG API — https://rawg.io/apidocs
RAWG_API_KEY=

# Admin badge panel — comma-separated Clerk user IDs
ADMIN_CLERK_IDS=

# Product analytics (PostHog free tier) — leave empty to disable (silent no-op)
# https://us.posthog.com → Project settings → Project API Key
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Optional server-only key (defaults to PUBLIC_POSTHOG_KEY)
POSTHOG_API_KEY=

# Affiliate — Instant Gaming partner id (?igr=…). Leave empty → Steam utility links only
# https://www.instant-gaming.com/en/partnership/
PUBLIC_INSTANT_GAMING_AFFILIATE_ID=
